///|
/// Bridge library entry point.
/// Ensures all FFI exports are reachable in the generated C output.
fn main {
  let rows = @utf8.encode("24")
  let cols = @utf8.encode("80")
  let key = @utf8.encode("65")
  let mods = @utf8.encode("0")
  let gained = @utf8.encode("1")
  let data = @utf8.encode("hello")
  // Legacy single-session API
  let _r1 = @bridge.ffi_init(rows, cols)
  let _r2 = @bridge.ffi_process_output(data)
  let _r3 = @bridge.ffi_handle_key(key, mods)
  let _r4 = @bridge.ffi_resize(rows, cols)
  let _r5 = @bridge.ffi_get_title()
  let _r5b = @bridge.ffi_get_cursor()
  let _r6 = @bridge.ffi_get_grid()
  let _r7 = @bridge.ffi_get_modes()
  let _r8 = @bridge.ffi_focus_event(gained)
  // Session management
  let _s1 : Bytes = @bridge.ffi_create_session(rows, cols)
  let _s2 = @bridge.ffi_destroy_session(@utf8.encode("1"))
  let _s3 = @bridge.ffi_switch_session(@utf8.encode("1"))
  let _s4 = @bridge.ffi_list_sessions()
  let _s5 = @bridge.ffi_get_active_session()
  // GPU rendering exports
  let surface = @utf8.encode("0")
  let width = @utf8.encode("640")
  let height = @utf8.encode("480")
  let _r10 = @bridge.ffi_gpu_init(surface, width, height)
  let _r11 = @bridge.ffi_render_frame()
  let _r11b = @bridge.ffi_render_frame_for(@utf8.encode("1"))
  let _r12 = @bridge.ffi_gpu_resize(width, height)
  // GPU multi-surface
  let _gpu1 = @bridge.ffi_gpu_register_surface(@utf8.encode("1"), @utf8.encode("0"))
  let _gpu2 = @bridge.ffi_gpu_surface_destroy(@utf8.encode("1"))
  let _gpu3 = @bridge.ffi_gpu_surface_resize(@utf8.encode("1"), width, height)
  let _r13 = @bridge.ffi_classify_key(key, mods, @utf8.encode("0"))
  // Tab & Panel management (layout-aware)
  let _tab1 : Bytes = @bridge.ffi_create_tab(rows, cols)
  let _tab2 = @bridge.ffi_close_tab(@utf8.encode("1"))
  let _tab3 = @bridge.ffi_switch_tab(@utf8.encode("1"))
  let _tab4 = @bridge.ffi_next_tab()
  let _tab5 = @bridge.ffi_prev_tab()
  let _tab6 = @bridge.ffi_list_tabs()
  let _p1 : Bytes = @bridge.ffi_split_panel(@utf8.encode("1"), @utf8.encode("0"))
  let _p2 = @bridge.ffi_close_panel(@utf8.encode("1"))
  let _p3 = @bridge.ffi_focus_panel(@utf8.encode("1"))
  let _p4 = @bridge.ffi_focus_panel_by_index(@utf8.encode("0"))
  let _p5 = @bridge.ffi_focus_direction(@utf8.encode("0"))
  let _p9 : Bytes = @bridge.ffi_notify_panel_resize(@utf8.encode("1"), @utf8.encode("200"), @utf8.encode("400"))
  let _p10 : Bytes = @bridge.ffi_resize_layout(rows, cols)
  let _p10b : Bytes = @bridge.ffi_resize_layout_px(@utf8.encode("640"), @utf8.encode("480"))
  let _p6 = @bridge.ffi_get_layout()
  let _p7 = @bridge.ffi_get_all_panels()
  let _p8 = @bridge.ffi_get_focused_panel_id()
  // Session-targeted operations
  let _st1 = @bridge.ffi_process_output_for(@utf8.encode("1"), data)
  let _st2 = @bridge.ffi_get_grid_for(@utf8.encode("1"))
  let _st3 = @bridge.ffi_handle_key_for(@utf8.encode("1"), key, mods)
  let _st4 = @bridge.ffi_resize_session(@utf8.encode("1"), rows, cols)
  let _px2g = @bridge.ffi_pixel_to_grid(@utf8.encode("100"), @utf8.encode("200"), @utf8.encode("480"))
  // Theme & metrics
  let _t1 = @bridge.ffi_get_theme()
  let _cm1 = @bridge.ffi_get_cell_metrics()
  // Shutdown (must be last)
  let _r9 = @bridge.ffi_shutdown()
  println("bridge_lib: all exports referenced")
}
